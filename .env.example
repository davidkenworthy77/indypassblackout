# ── Vercel serverless read endpoint (/api/data) — set these in Vercel ──
# Project Settings → Environment Variables. These are server-side (no VITE_).
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxx

# ── Admin app (Vite, client-side) — lives in admin/.env ───────────────
# Only VITE_-prefixed vars are exposed to the browser. The publishable/anon
# key is safe to ship publicly; row-level security protects writes.
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxx
