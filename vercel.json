{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm install && npm run build:all",
  "outputDirectory": ".",
  "cleanUrls": false,
  "functions": {
    "api/*.ts": { "maxDuration": 10 }
  },
  "redirects": [{ "source": "/admin", "destination": "/admin/", "permanent": false }],
  "rewrites": [
    { "source": "/", "destination": "/index.html" },
    { "source": "/admin/", "destination": "/admin/dist/index.html" },
    { "source": "/admin/assets/(.*)", "destination": "/admin/dist/assets/$1" },
    { "source": "/admin/data.json", "destination": "/admin/dist/data.json" }
  ]
}
